---
kind: Cluster
apiVersion: kind.x-k8s.io/v1alpha4
networking:
  apiServerPort: {{ cluster_api_port }}
nodes:
  - role: control-plane
    kubeadmConfigPatches:
      - |
        kind: InitConfiguration
        nodeRegistration:
          kubeletExtraArgs:
            node-labels: "ingress-ready=true"
    extraPortMappings:
      - containerPort: 80
        hostPort: {{ cluster_http_port }}
        protocol: TCP
      - containerPort: 443
        hostPort: {{ cluster_https_port }}
        protocol: TCP
{% for i in range(cluster_worker_count | int) %}
  - role: worker
{% endfor %}
