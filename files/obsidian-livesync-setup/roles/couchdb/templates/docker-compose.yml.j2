services:
  couchdb:
    container_name: {{ couchdb_container_name }}
    image: {{ couchdb_image }}
    restart: {{ couchdb_restart_policy }}
    environment:
      COUCHDB_USER: "{{ couchdb_admin_user }}"
      COUCHDB_PASSWORD: "{{ couchdb_admin_password }}"
    ports:
      - "{{ couchdb_bind_address }}:{{ couchdb_port }}:5984"
    volumes:
      - {{ couchdb_data_dir }}/data:/opt/couchdb/data
      - {{ couchdb_data_dir }}/local.ini:/opt/couchdb/etc/local.d/local.ini:ro
    networks:
      - databases-net
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:5984/_up"]
      interval: 30s
      timeout: 10s
      retries: 5
      start_period: 30s

networks:
  databases-net:
    external: true
