services:
{% if not paperless_use_shared_redis %}
  redis:
    container_name: {{ paperless_container_name }}-redis
    image: {{ paperless_redis_image }}
    restart: {{ paperless_restart_policy }}
    volumes:
      - paperless-redis-data:/data
    networks:
      - paperless-net

{% endif %}
{% if not paperless_use_shared_db %}
  db:
    container_name: {{ paperless_container_name }}-db
    image: {{ paperless_postgres_image }}
    restart: {{ paperless_restart_policy }}
    environment:
      POSTGRES_DB: paperless
      POSTGRES_USER: paperless
      POSTGRES_PASSWORD: "{{ paperless_db_password }}"
    volumes:
      - paperless-db-data:/var/lib/postgresql/data
    networks:
      - paperless-net

{% endif %}
  webserver:
    container_name: {{ paperless_container_name }}
    image: {{ paperless_image }}
    restart: {{ paperless_restart_policy }}
{% if not (paperless_use_shared_db and paperless_use_shared_redis) %}
    depends_on:
{% if not paperless_use_shared_db %}
      - db
{% endif %}
{% if not paperless_use_shared_redis %}
      - redis
{% endif %}
{% endif %}
    ports:
      - "{{ paperless_bind_address }}:{{ paperless_port }}:8000"
    volumes:
      - paperless-data:/usr/src/paperless/data
{% if paperless_document_path | length > 0 %}
      - {{ paperless_document_path }}:/usr/src/paperless/media
{% else %}
      - paperless-media:/usr/src/paperless/media
{% endif %}
    environment:
{% if paperless_use_shared_redis %}
      PAPERLESS_REDIS: "redis://:{{ paperless_shared_redis_password }}@{{ paperless_redis_host }}:6379/{{ paperless_redis_db }}"
{% else %}
      PAPERLESS_REDIS: "redis://redis:6379"
{% endif %}
      PAPERLESS_DBHOST: "{{ paperless_db_host }}"
      PAPERLESS_DBPASS: "{{ paperless_db_password }}"
      PAPERLESS_SECRET_KEY: "{{ paperless_secret_key }}"
      PAPERLESS_ADMIN_USER: "{{ paperless_admin_user }}"
      PAPERLESS_ADMIN_PASSWORD: "{{ paperless_admin_password }}"
{% if paperless_public_url | length > 0 %}
      PAPERLESS_URL: "{{ paperless_public_url }}"
{% endif %}
      # ── Authelia header SSO ─────────────────────────────────────────────────
      # Caddy's forward_auth passes Remote-User from Authelia; Paperless trusts
      # it and creates/resumes a session automatically.
      PAPERLESS_ENABLE_HTTP_REMOTE_USER: "true"
      PAPERLESS_HTTP_REMOTE_USER_HEADER_NAME: "HTTP_REMOTE_USER"
    networks:
      - paperless-net
{% if paperless_use_shared_db or paperless_use_shared_redis %}
      - databases-net
{% endif %}

volumes:
{% if not paperless_use_shared_redis %}
  paperless-redis-data:
{% endif %}
{% if not paperless_use_shared_db %}
  paperless-db-data:
{% endif %}
  paperless-data:
{% if paperless_document_path | length == 0 %}
  paperless-media:
{% endif %}

networks:
  paperless-net:
    driver: bridge
{% if paperless_use_shared_db or paperless_use_shared_redis %}
  databases-net:
    external: true
{% endif %}
