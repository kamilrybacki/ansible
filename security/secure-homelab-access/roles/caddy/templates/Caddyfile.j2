{
{% if not cf_tunnel_name | default('') %}
	email {{ caddy_email }}
{% endif %}

	crowdsec {
		api_url http://{{ crowdsec_container_name }}:{{ crowdsec_lapi_port }}
		api_key {$CROWDSEC_API_KEY}
		ticker_interval 15s
	}

{% if cf_tunnel_name | default('') %}
	servers {
		trusted_proxies static private_ranges
		metrics
	}
{% else %}
	servers {
		metrics
	}
{% endif %}

	admin 0.0.0.0:2019
}

# -- Snippets -----------------------------------------------------------------

(authelia) {
	forward_auth {{ authelia_container_name }}:9091 {
		uri /api/authz/forward-auth
		copy_headers Remote-User Remote-Groups Remote-Name Remote-Email
		header_up X-Forwarded-Proto https
	}
}

(rate_limit) {
	@wan {
		not remote_ip private_ranges
	}
	rate_limit @wan {
		zone dynamic {
			key {remote_host}
			events {{ caddy_rate_limit_requests }}
			window {{ caddy_rate_limit_window }}
		}
	}
}

# Ensures backends always see X-Forwarded-Proto: https regardless of whether
# Caddy received the request over HTTP (Cloudflare Tunnel) or HTTPS (direct).
# Without this, Django CSRF checks, n8n and others serve blank
# pages or reject requests because they think the client is on plain HTTP.
(proxy_headers) {
	request_header X-Forwarded-Proto https
}

{% if cloudflare_api_token | default('') %}
(cf_tls) {
	tls {
		dns cloudflare {$CF_API_TOKEN}
	}
}
{% endif %}

# -- Services -----------------------------------------------------------------
# When a Cloudflare Tunnel is active, Cloudflare terminates TLS at the edge
# and sends plain HTTP to localhost:80. Use http:// prefix so Caddy does not
# attempt ACME and serves plain HTTP instead of redirecting to HTTPS.
{% if cf_tunnel_name | default('') %}
{% set _scheme = 'http://' %}
{% else %}
{% set _scheme = '' %}
{% endif %}

# Authelia portal
{{ _scheme }}{{ subdomain_auth }}.{{ domain }} {
	import rate_limit
	import proxy_headers
{% if cloudflare_api_token | default('') and not cf_tunnel_name | default('') %}
	import cf_tls
{% endif %}
	reverse_proxy {{ authelia_container_name }}:9091
}

# Homepage dashboard
{{ _scheme }}{{ subdomain_home }}.{{ domain }} {
	import rate_limit
	import proxy_headers
{% if cloudflare_api_token | default('') and not cf_tunnel_name | default('') %}
	import cf_tls
{% endif %}
	import authelia
	reverse_proxy {{ homepage_container_name }}:3000
}

# Cockpit system management + terminal (no Authelia — Cockpit uses Linux PAM)
{{ _scheme }}{{ subdomain_cockpit }}.{{ domain }} {
	import rate_limit
	import proxy_headers
{% if cloudflare_api_token | default('') and not cf_tunnel_name | default('') %}
	import cf_tls
{% endif %}
	reverse_proxy https://{{ docker_gateway_ip }}:{{ cockpit_port }} {
		transport http {
			tls_insecure_skip_verify
		}
		header_up Host {{ subdomain_cockpit }}.{{ domain }}
		header_up Authorization "Basic {$COCKPIT_BASIC_AUTH}"
		header_down -WWW-Authenticate
	}
}

