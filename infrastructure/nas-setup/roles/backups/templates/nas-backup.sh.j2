#!/bin/bash
# NAS backup script — rsync from mergerfs pool to internal storage
# Generated by Ansible - do not edit manually

LOG="{{ backup_log }}"
TIMESTAMP=$(date '+%Y-%m-%d %H:%M:%S')

echo "[$TIMESTAMP] Starting NAS backup..." >> "$LOG"

# Ensure backup destination exists
mkdir -p "{{ backup_dest }}"

# Run rsync
rsync {{ backup_rsync_opts }} "{{ backup_source }}/" "{{ backup_dest }}/" >> "$LOG" 2>&1
RSYNC_EXIT=$?

TIMESTAMP=$(date '+%Y-%m-%d %H:%M:%S')
if [ $RSYNC_EXIT -eq 0 ]; then
    echo "[$TIMESTAMP] Backup completed successfully." >> "$LOG"
else
    echo "[$TIMESTAMP] ERROR: Backup failed with exit code $RSYNC_EXIT" >> "$LOG"
fi

# Rotate logs older than {{ backup_retention_days }} days
find "$(dirname $LOG)" -name "$(basename $LOG).*" -mtime +{{ backup_retention_days }} -delete 2>/dev/null

exit $RSYNC_EXIT
