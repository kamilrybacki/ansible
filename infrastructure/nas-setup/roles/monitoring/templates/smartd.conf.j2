# smartd configuration - Generated by Ansible
# Monitor all NAS drives and send email alerts on issues

# USB data drives
{% for drive in usb_data_drives %}
{{ drive }} -a -o on -S on -n standby,q -s (S/../.././02|L/../../6/03) -W 4,45,50 -m {{ smartd_alert_email }}
{% endfor %}

# USB parity drives
{% for drive in usb_parity_drives %}
{{ drive }} -a -o on -S on -n standby,q -s (S/../.././02|L/../../6/03) -W 4,45,50 -m {{ smartd_alert_email }}
{% endfor %}

# Internal HDD
{{ internal_drive }} -a -o on -S on -n standby,q -s (S/../.././02|L/../../6/03) -W 4,45,50 -m {{ smartd_alert_email }}
