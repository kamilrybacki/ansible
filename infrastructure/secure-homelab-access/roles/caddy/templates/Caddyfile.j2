{
	email {{ caddy_email }}

	crowdsec {
		api_url http://{{ crowdsec_container_name }}:{{ crowdsec_lapi_port }}
		api_key {$CROWDSEC_API_KEY}
		ticker_interval 15s
	}
}

# -- Snippets -----------------------------------------------------------------

(authelia) {
	forward_auth {{ authelia_container_name }}:9091 {
		uri /api/authz/forward-auth
		copy_headers Remote-User Remote-Groups Remote-Name Remote-Email
	}
}

(rate_limit) {
	rate_limit {
		zone dynamic {
			key {remote_host}
			events {{ caddy_rate_limit_requests }}
			window {{ caddy_rate_limit_window }}
		}
	}
}

{% if cloudflare_api_token | default('') %}
(cf_tls) {
	tls {
		dns cloudflare {$CF_API_TOKEN}
	}
}
{% endif %}

# -- Services -----------------------------------------------------------------

# Authelia portal
{{ subdomain_auth }}.{{ domain }} {
	import rate_limit
{% if cloudflare_api_token | default('') %}
	import cf_tls
{% endif %}
	reverse_proxy {{ authelia_container_name }}:9091
}

# Homepage dashboard
{{ subdomain_home }}.{{ domain }} {
	import rate_limit
{% if cloudflare_api_token | default('') %}
	import cf_tls
{% endif %}
	import authelia
	reverse_proxy {{ homepage_container_name }}:3000
}

# Cockpit system management + terminal
{{ subdomain_cockpit }}.{{ domain }} {
	import rate_limit
{% if cloudflare_api_token | default('') %}
	import cf_tls
{% endif %}
	import authelia
	reverse_proxy localhost:{{ cockpit_port }}
}

# WireGuard admin UI
{{ subdomain_wireguard }}.{{ domain }} {
	import rate_limit
{% if cloudflare_api_token | default('') %}
	import cf_tls
{% endif %}
	import authelia
	reverse_proxy {{ wireguard_container_name }}:51821
}

# Pi-hole DNS dashboard
{{ subdomain_pihole }}.{{ domain }} {
	import rate_limit
{% if cloudflare_api_token | default('') %}
	import cf_tls
{% endif %}
	import authelia
	reverse_proxy {{ pihole_container_name }}:{{ pihole_web_port }}
}
