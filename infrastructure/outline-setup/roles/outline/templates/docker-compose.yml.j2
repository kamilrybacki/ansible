---
services:

  outline:
    container_name: {{ outline_container_name }}
    image: {{ outline_image }}
    depends_on:
{% if not outline_use_shared_db %}
      - postgres
{% endif %}
{% if not outline_use_shared_redis %}
      - redis
{% endif %}
    ports:
      - "{{ outline_bind_address }}:{{ outline_port }}:3000"
    environment:
      NODE_ENV: production
      SECRET_KEY: "{{ outline_secret_key }}"
      UTILS_SECRET: "{{ outline_utils_secret }}"
      DATABASE_URL: "postgresql://outline:{{ outline_db_password }}@{{ outline_db_host }}/outline"
      PGSSLMODE: disable
{% if outline_use_shared_redis %}
      REDIS_URL: "redis://:{{ outline_shared_redis_password }}@{{ outline_redis_host }}:6379/{{ outline_redis_db }}"
{% else %}
      REDIS_URL: "redis://:{{ outline_redis_password }}@redis:6379"
{% endif %}
      URL: "{{ outline_public_url if outline_public_url | length > 0 else 'http://localhost:' + outline_port | string }}"
      FORCE_HTTPS: "false"
      ENABLE_UPDATES: "false"
      WEB_CONCURRENCY: "1"
      MAXIMUM_IMPORT_SIZE: "26214400"
      DEFAULT_LANGUAGE: en_US
      FILE_STORAGE: local
      FILE_STORAGE_LOCAL_ROOT_DIR: /var/lib/outline/data
      FILE_STORAGE_UPLOAD_MAX_SIZE: "26214400"
{% if outline_smtp_host | length > 0 %}
      SMTP_HOST: "{{ outline_smtp_host }}"
      SMTP_PORT: "{{ outline_smtp_port }}"
      SMTP_USERNAME: "{{ outline_smtp_username }}"
      SMTP_PASSWORD: "{{ outline_smtp_password }}"
      SMTP_FROM_EMAIL: "{{ outline_smtp_from_email }}"
      SMTP_REPLY_EMAIL: "{{ outline_smtp_reply_to_email }}"
      SMTP_SECURE: "{{ 'true' if outline_smtp_port | int == 465 else 'false' }}"
{% endif %}
{% if outline_oidc_client_id | length > 0 %}
      OIDC_CLIENT_ID: "{{ outline_oidc_client_id }}"
      OIDC_CLIENT_SECRET: "{{ outline_oidc_client_secret }}"
      OIDC_AUTH_URI: "{{ outline_oidc_auth_uri }}"
      OIDC_TOKEN_URI: "{{ outline_oidc_token_uri }}"
      OIDC_USERINFO_URI: "{{ outline_oidc_userinfo_uri }}"
      OIDC_USERNAME_CLAIM: preferred_username
      OIDC_DISPLAY_NAME: "{{ outline_oidc_display_name }}"
      OIDC_SCOPES: "openid profile email"
{% endif %}
    volumes:
      - outline-data:/var/lib/outline/data
    restart: {{ outline_restart_policy }}
    networks:
      - outline-net
{% if outline_use_shared_db or outline_use_shared_redis %}
      - databases-net
{% endif %}

{% if not outline_use_shared_db %}
  postgres:
    container_name: {{ outline_container_name }}-postgres
    image: {{ outline_postgres_image }}
    environment:
      POSTGRES_DB: outline
      POSTGRES_USER: outline
      POSTGRES_PASSWORD: "{{ outline_db_password }}"
    volumes:
      - outline-postgres-data:/var/lib/postgresql/data
    restart: {{ outline_restart_policy }}
    networks:
      - outline-net

{% endif %}
{% if not outline_use_shared_redis %}
  redis:
    container_name: {{ outline_container_name }}-redis
    image: {{ outline_redis_image }}
    command: valkey-server --requirepass {{ outline_redis_password }}
    volumes:
      - outline-redis-data:/data
    restart: {{ outline_restart_policy }}
    networks:
      - outline-net

{% endif %}
volumes:
  outline-data:
{% if not outline_use_shared_db %}
  outline-postgres-data:
{% endif %}
{% if not outline_use_shared_redis %}
  outline-redis-data:
{% endif %}

networks:
  outline-net:
    driver: bridge
{% if outline_use_shared_db or outline_use_shared_redis %}
  databases-net:
    external: true
{% endif %}
