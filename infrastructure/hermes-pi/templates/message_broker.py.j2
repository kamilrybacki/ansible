"""Hermes message broker — Redis-backed event bus for session synchronization.

Watches webui sessions for changes and publishes events to Redis.
Serves SSE endpoint for browser live-reload notifications.
"""

import asyncio
import json
import logging
import os
import threading
import time
import urllib.request
from http.server import HTTPServer, BaseHTTPRequestHandler

import redis

logging.basicConfig(level=logging.INFO, format="%(asctime)s [%(name)s] %(message)s")
log = logging.getLogger("broker")

WEBUI_URL = os.environ.get("WEBUI_URL", "http://hermes-webui:8788")
REDIS_URL = os.environ.get("REDIS_URL", "redis://redis:6379/0")
POLL_INTERVAL = int(os.environ.get("POLL_INTERVAL", "2"))
SSE_PORT = int(os.environ.get("SSE_PORT", "8789"))

CHANNEL = "hermes:messages"

# Track session message counts
_session_counts: dict[str, int] = {}


def _webui_get(path: str) -> dict:
    r = urllib.request.urlopen(f"{WEBUI_URL}{path}", timeout=10)
    return json.loads(r.read().decode())


def _poll_sessions(rc: redis.Redis):
    """Poll webui sessions and publish new messages to Redis."""
    while True:
        try:
            data = _webui_get("/api/sessions")
            sessions = data.get("sessions", [])

            for s in sessions:
                sid = s.get("session_id", "")
                count = s.get("message_count", 0)
                prev = _session_counts.get(sid, 0)

                if count > prev and prev > 0:
                    # Fetch the new messages
                    session_data = _webui_get(f"/api/session?session_id={sid}")
                    messages = session_data["session"].get("messages", [])
                    new_msgs = messages[prev:]

                    for msg in new_msgs:
                        event = {
                            "type": "new_message",
                            "session_id": sid,
                            "role": msg.get("role", ""),
                            "content": str(msg.get("content", ""))[:4000],
                            "source": "webui",
                            "ts": time.time(),
                        }
                        rc.publish(CHANNEL, json.dumps(event))
                        log.info("Published %s message in session %s", msg.get("role"), sid[:8])

                _session_counts[sid] = count

        except Exception as e:
            log.debug("Poll error: %s", e)

        time.sleep(POLL_INTERVAL)


# ── SSE notification server for browser ───────────────────────────────

_sse_clients: list = []
_sse_lock = threading.Lock()


class SSEHandler(BaseHTTPRequestHandler):
    def do_GET(self):
        if self.path == "/health":
            self.send_response(200)
            self.send_header("Content-Type", "text/plain")
            self.end_headers()
            self.wfile.write(b"ok")
            return

        if self.path.startswith("/events"):
            self.send_response(200)
            self.send_header("Content-Type", "text/event-stream")
            self.send_header("Cache-Control", "no-cache")
            self.send_header("Access-Control-Allow-Origin", "*")
            self.send_header("Connection", "keep-alive")
            self.end_headers()

            q = []
            with _sse_lock:
                _sse_clients.append(q)

            try:
                while True:
                    if q:
                        event = q.pop(0)
                        self.wfile.write(f"event: message\ndata: {json.dumps(event)}\n\n".encode())
                        self.wfile.flush()
                    else:
                        # Heartbeat
                        self.wfile.write(b": heartbeat\n\n")
                        self.wfile.flush()
                        time.sleep(1)
            except (BrokenPipeError, ConnectionResetError):
                pass
            finally:
                with _sse_lock:
                    if q in _sse_clients:
                        _sse_clients.remove(q)
            return

        self.send_response(404)
        self.end_headers()

    def log_message(self, format, *args):
        pass  # Quiet


def _redis_to_sse(rc: redis.Redis):
    """Subscribe to Redis and forward events to SSE clients."""
    pubsub = rc.pubsub()
    pubsub.subscribe(CHANNEL)

    for message in pubsub.listen():
        if message["type"] != "message":
            continue
        try:
            event = json.loads(message["data"])
        except (json.JSONDecodeError, TypeError):
            continue

        with _sse_lock:
            for client_q in _sse_clients:
                client_q.append(event)


def main():
    rc = redis.from_url(REDIS_URL)
    rc.ping()
    log.info("Connected to Redis")

    # Start session poller
    threading.Thread(target=_poll_sessions, args=(rc,), daemon=True).start()

    # Start Redis → SSE forwarder
    threading.Thread(target=_redis_to_sse, args=(rc,), daemon=True).start()

    # Start SSE HTTP server
    server = HTTPServer(("0.0.0.0", SSE_PORT), SSEHandler)
    log.info("Broker started (SSE on :%d, polling every %ds)", SSE_PORT, POLL_INTERVAL)
    server.serve_forever()


if __name__ == "__main__":
    main()
