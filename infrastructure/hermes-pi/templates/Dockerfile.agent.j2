FROM python:3.12-slim

RUN apt-get update -qq && \
    apt-get install -y -qq --no-install-recommends git curl ca-certificates && \
    rm -rf /var/lib/apt/lists/*

COPY agent-code /opt/hermes
RUN pip install --no-cache-dir -e /opt/hermes && \
    pip install --no-cache-dir python-telegram-bot==22.7

WORKDIR /opt/data
ENTRYPOINT ["hermes"]
