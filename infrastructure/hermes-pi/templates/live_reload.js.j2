/* Hermes live-reload: connects to broker SSE and refreshes chat on new messages */
(function() {
  var evtSrc = null;
  function connect() {
    evtSrc = new EventSource('/broker/events');
    evtSrc.addEventListener('message', function(e) {
      try {
        var data = JSON.parse(e.data);
        if (data.type === 'new_message') {
          // Trigger the webui to re-fetch the session
          var sessionLinks = document.querySelectorAll('[data-session-id]');
          // Simplest: dispatch a custom event the app might listen to,
          // or just click the active session to force reload
          var active = document.querySelector('.session-item.active, .conversation-item.active, [class*="active"]');
          if (active) active.click();
        }
      } catch(err) {}
    });
    evtSrc.onerror = function() {
      evtSrc.close();
      setTimeout(connect, 5000);
    };
  }
  // Wait for page load
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', connect);
  } else {
    connect();
  }
})();
