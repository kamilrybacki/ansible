server {
    listen 8787;
    location /healthz {
        return 200 'ok';
        add_header Content-Type text/plain;
    }
    location / {
        proxy_pass http://{{ k8s_node_ip }}:30787;
        proxy_set_header Host {{ k8s_node_ip }};
        proxy_set_header x-portkey-config '{"strategy":{"mode":"single"},"targets":[{"provider":"groq","api_key":"{{ groq_api_key }}"}]}';
        proxy_pass_request_headers on;
        proxy_http_version 1.1;
        proxy_read_timeout 120s;
    }
}
