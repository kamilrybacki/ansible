# Managed by Ansible — do not edit manually
network:
  version: 2
  ethernets:
    {{ nas_iface }}:
      match:
        macaddress: "{{ nas_mac }}"
      addresses:
        - {{ nas_ip }}/{{ nas_prefix }}
      routes:
        - to: default
          via: {{ nas_gateway }}
      nameservers:
        addresses:
          - 1.1.1.1
          - 8.8.8.8
      link-local: []
