# OpenClaw Docker Compose – managed by Ansible
services:
  openclaw:
    image: {{ openclaw_image }}
    container_name: openclaw
    ports:
      - "{{ openclaw_bind_address }}:{{ openclaw_gateway_port }}:18789"
    volumes:
      - ./config.json:/app/config.json:ro
      - ./data:/app/data
    environment:
{% if openclaw_nvidia_api_key | default('') | length > 0 %}
      NVIDIA_API_KEY: "{{ openclaw_nvidia_api_key }}"
{% endif %}
{% if openclaw_groq_api_key | default('') | length > 0 %}
      GROQ_API_KEY: "{{ openclaw_groq_api_key }}"
{% endif %}
{% if openclaw_gemini_api_key | default('') | length > 0 %}
      GEMINI_API_KEY: "{{ openclaw_gemini_api_key }}"
{% endif %}
{% if openclaw_deepseek_api_key | default('') | length > 0 %}
      DEEPSEEK_API_KEY: "{{ openclaw_deepseek_api_key }}"
{% endif %}
{% if openclaw_ollama_enabled %}
      OLLAMA_API_KEY: "ollama-local"
{% endif %}
{% if openclaw_ollama_enabled %}
    depends_on:
      ollama:
        condition: service_healthy
    networks:
      - openclaw-net
{% endif %}
    restart: unless-stopped
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:18789/health"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 30s

{% if openclaw_ollama_enabled %}
  ollama:
    image: {{ openclaw_ollama_image }}
    container_name: ollama
    ports:
      - "{{ openclaw_bind_address }}:11434:11434"
    volumes:
      - ./ollama-data:/root/.ollama
{% if openclaw_ollama_gpu_enabled %}
    deploy:
      resources:
        reservations:
          devices:
            - driver: nvidia
              count: all
              capabilities: [gpu]
{% endif %}
    restart: unless-stopped
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:11434/api/tags"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 30s
    networks:
      - openclaw-net

networks:
  openclaw-net:
    driver: bridge
{% endif %}
