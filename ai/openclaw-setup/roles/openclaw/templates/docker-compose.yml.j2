# OpenClaw Docker Compose – managed by Ansible
services:
  openclaw:
    image: {{ openclaw_image }}
    container_name: openclaw
    ports:
      - "{{ openclaw_bind_address }}:{{ openclaw_gateway_port }}:18789"
    volumes:
      - ./data:/app/data
      - ./openclaw-home:/home/node/.openclaw
      - openclaw-logs:/tmp/openclaw
    environment:
{% if openclaw_nvidia_api_key | default('') | length > 0 %}
      NVIDIA_API_KEY: "{{ openclaw_nvidia_api_key }}"
{% endif %}
{% if openclaw_groq_api_key | default('') | length > 0 %}
      GROQ_API_KEY: "{{ openclaw_groq_api_key }}"
{% endif %}
{% if openclaw_gemini_api_key | default('') | length > 0 %}
      GEMINI_API_KEY: "{{ openclaw_gemini_api_key }}"
{% endif %}
{% if openclaw_deepseek_api_key | default('') | length > 0 %}
      DEEPSEEK_API_KEY: "{{ openclaw_deepseek_api_key }}"
{% endif %}
{% if openclaw_ollama_enabled %}
      OLLAMA_API_KEY: "ollama-local"
{% endif %}
{% if openclaw_ollama_enabled %}
    depends_on:
      ollama:
        condition: service_healthy
{% endif %}
    networks:
      - homelab-net
{% if openclaw_ollama_enabled or openclaw_metrics_enabled %}
      - openclaw-net
{% endif %}
    restart: unless-stopped
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:18789/health"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 30s

  # OpenClaw hardcodes binding to 127.0.0.1 inside the container, so other
  # containers on homelab-net cannot reach it directly. This socat sidecar
  # shares OpenClaw's network namespace and forwards 0.0.0.0:{{ openclaw_proxy_port }}
  # to 127.0.0.1:18789, making the service accessible to Caddy by container name.
  openclaw-proxy:
    image: alpine/socat
    container_name: openclaw-proxy
    network_mode: "service:openclaw"
    command: "TCP-LISTEN:{{ openclaw_proxy_port }},fork,reuseaddr TCP:127.0.0.1:18789"
    restart: unless-stopped
    depends_on:
      openclaw:
        condition: service_healthy

{% if openclaw_metrics_enabled %}
  openclaw-metrics:
    build:
      context: ./openclaw-metrics
    container_name: openclaw-metrics
    ports:
      - "127.0.0.1:{{ openclaw_metrics_port }}:9101"
    volumes:
      - ./openclaw-home:/data/openclaw-home:ro
      - openclaw-logs:/data/openclaw-logs:ro
    environment:
      METRICS_PORT: "9101"
      SESSIONS_DIR: "/data/openclaw-home"
      LOGS_DIR: "/data/openclaw-logs"
    networks:
      - openclaw-net
    restart: unless-stopped
    mem_limit: 256m
    cpus: 0.5
    healthcheck:
      test: ["CMD", "python3", "-c", "import urllib.request; urllib.request.urlopen('http://localhost:9101/metrics')"]
      interval: 30s
      timeout: 5s
      retries: 3
    depends_on:
      openclaw:
        condition: service_healthy
{% endif %}

{% if openclaw_ollama_enabled %}
  ollama:
    image: {{ openclaw_ollama_image }}
    container_name: ollama
    volumes:
      - ./ollama-data:/root/.ollama
{% if openclaw_ollama_gpu_enabled %}
    deploy:
      resources:
        reservations:
          devices:
            - driver: nvidia
              count: all
              capabilities: [gpu]
{% endif %}
    restart: unless-stopped
    healthcheck:
      test: ["CMD", "ollama", "ls"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 30s
    networks:
      - openclaw-net
{% endif %}

{% if openclaw_metrics_enabled %}
volumes:
  openclaw-logs:

{% endif %}
networks:
  homelab-net:
    external: true
{% if openclaw_ollama_enabled or openclaw_metrics_enabled %}
  openclaw-net:
    driver: bridge
{% endif %}
