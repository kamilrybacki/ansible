{
  "models": {
    "providers": {
{% if openclaw_nvidia_api_key | default('') | length > 0 %}
      "nvidia": {
        "apiKey": "{{ openclaw_nvidia_api_key }}",
        "baseUrl": "https://integrate.api.nvidia.com/v1",
        "api": "openai-completions",
        "models": [
          { "id": "moonshotai/kimi-k2.5", "name": "Kimi K2.5", "contextWindow": 131072, "cost": { "input": 0, "output": 0 } },
          { "id": "minimaxai/minimax-m2.5", "name": "MiniMax M2.5", "contextWindow": 131072, "cost": { "input": 0, "output": 0 } },
          { "id": "z-ai/glm5", "name": "GLM-5 744B", "contextWindow": 131072, "cost": { "input": 0, "output": 0 } },
          { "id": "z-ai/glm4.7", "name": "GLM-4.7 Agentic", "contextWindow": 131072, "cost": { "input": 0, "output": 0 } },
          { "id": "nvidia/llama-3.3-nemotron-super-49b-v1.5", "name": "Nemotron Super 49B", "contextWindow": 131072, "cost": { "input": 0, "output": 0 } },
          { "id": "qwen/qwen3.5-397b-a17b", "name": "Qwen 3.5 397B", "contextWindow": 131072, "cost": { "input": 0, "output": 0 } }
        ]
      }{{ ',' if (openclaw_groq_api_key | default('') | length > 0) or (openclaw_gemini_api_key | default('') | length > 0) or (openclaw_deepseek_api_key | default('') | length > 0) or openclaw_ollama_enabled else '' }}
{% endif %}
{% if openclaw_groq_api_key | default('') | length > 0 %}
      "groq": {
        "apiKey": "{{ openclaw_groq_api_key }}",
        "baseUrl": "https://api.groq.com/openai/v1",
        "api": "openai-completions",
        "models": [
          { "id": "llama-3.3-70b-versatile", "name": "Llama 3.3 70B", "contextWindow": 131072, "cost": { "input": 0, "output": 0 } },
          { "id": "llama-4-scout-17b-16e-instruct", "name": "Llama 4 Scout 17B", "contextWindow": 131072, "cost": { "input": 0, "output": 0 } },
          { "id": "whisper-large-v3-turbo", "name": "Whisper Large V3 Turbo", "contextWindow": 1, "cost": { "input": 0, "output": 0 } }
        ]
      }{{ ',' if (openclaw_gemini_api_key | default('') | length > 0) or (openclaw_deepseek_api_key | default('') | length > 0) or openclaw_ollama_enabled else '' }}
{% endif %}
{% if openclaw_gemini_api_key | default('') | length > 0 %}
      "google": {
        "apiKey": "{{ openclaw_gemini_api_key }}",
        "baseUrl": "https://generativelanguage.googleapis.com/v1beta/openai",
        "api": "openai-completions",
        "models": [
          { "id": "gemini-2.5-flash", "name": "Gemini 2.5 Flash", "contextWindow": 1048576, "cost": { "input": 0, "output": 0 } }
        ]
      }{{ ',' if (openclaw_deepseek_api_key | default('') | length > 0) or openclaw_ollama_enabled else '' }}
{% endif %}
{% if openclaw_deepseek_api_key | default('') | length > 0 %}
      "deepseek": {
        "apiKey": "{{ openclaw_deepseek_api_key }}",
        "baseUrl": "https://api.deepseek.com/v1",
        "api": "openai-completions",
        "models": [
          { "id": "deepseek-chat", "name": "DeepSeek Chat V3", "contextWindow": 131072, "cost": { "input": 0.27, "output": 1.10 } },
          { "id": "deepseek-reasoner", "name": "DeepSeek Reasoner R1", "contextWindow": 131072, "cost": { "input": 0.55, "output": 2.20 } }
        ]
      }{{ ',' if openclaw_ollama_enabled else '' }}
{% endif %}
{% if openclaw_ollama_enabled %}
      "ollama": {
        "baseUrl": "{{ openclaw_ollama_base_url }}",
        "apiKey": "ollama-local",
        "api": "ollama",
        "models": [
          {
            "id": "{{ openclaw_ollama_model }}",
            "name": "{{ openclaw_ollama_model }} (local)",
            "contextWindow": {{ openclaw_ollama_context_window }},
            "cost": { "input": 0, "output": 0 }
          }
        ]
      }
{% endif %}
    }
  },

  "agents": {
    "defaults": {
      "model": "{{ openclaw_primary_model }}"
    }
  },

  "gateway": {
    "auth": {
      "mode": "trusted-proxy",
      "trustedProxy": {
        "userHeader": "X-Forwarded-For"
      }
    },
    "trustedProxies": ["127.0.0.1/8", "172.20.0.0/24"],
{% if openclaw_public_url | default('') | length > 0 %}
    "controlUi": {
      "allowedOrigins": ["{{ openclaw_public_url }}"]
    },
{% endif %}
    "port": {{ openclaw_gateway_port }}
  }
}
