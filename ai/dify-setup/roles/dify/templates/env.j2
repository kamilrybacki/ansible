# Dify environment – managed by Ansible
# -----------------------------------------------
# For the full list of variables see .env.example
# in the Dify repository's docker/ directory.
# -----------------------------------------------

# -- Compose profiles --
COMPOSE_PROFILES=postgresql,{{ dify_vector_store }}

# -- Exposure --
EXPOSE_NGINX_PORT={{ dify_http_port }}
EXPOSE_NGINX_SSL_PORT={{ dify_https_port }}
NGINX_HTTPS_ENABLED={{ dify_nginx_https_enabled | lower }}

# -- Security --
SECRET_KEY={{ dify_secret_key }}
{% if dify_init_password | default('') | length > 0 %}
INIT_PASSWORD={{ dify_init_password }}
{% endif %}

# -- Database --
DB_USERNAME=postgres
DB_PASSWORD={{ dify_db_password }}
DB_HOST=db_postgres
DB_PORT=5432
DB_DATABASE=dify

# -- Redis --
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD={{ dify_redis_password }}

# -- Vector store --
VECTOR_STORE={{ dify_vector_store }}

{% if dify_vector_store == 'weaviate' %}
WEAVIATE_ENDPOINT=http://weaviate:8080
WEAVIATE_GRPC_ENDPOINT=grpc://weaviate:50051
WEAVIATE_API_KEY=WVF5YThaHlkYwhGUSmCRgsX3tD5ngdN8pkih
{% elif dify_vector_store == 'qdrant' %}
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=difyai123456
{% elif dify_vector_store == 'pgvector' %}
PGVECTOR_HOST=pgvector
PGVECTOR_PORT=5432
PGVECTOR_USER=postgres
PGVECTOR_PASSWORD=difyai123456
PGVECTOR_DATABASE=dify
{% elif dify_vector_store == 'chroma' %}
CHROMA_HOST=chroma
CHROMA_PORT=8000
CHROMA_AUTH_CREDENTIALS=difyai123456
{% endif %}

# -- Sandbox --
SANDBOX_API_KEY=dify-sandbox
CODE_EXECUTION_ENDPOINT=http://sandbox:8194

# -- Plugin daemon --
PLUGIN_DAEMON_KEY={{ dify_plugin_daemon_key }}
PLUGIN_DIFY_INNER_API_KEY={{ dify_inner_api_key }}

# -- Storage --
STORAGE_TYPE=opendal
OPENDAL_SCHEME=fs
OPENDAL_FS_ROOT=storage

# -- Logging --
LOG_LEVEL=INFO

# -- SSRF proxy --
SSRF_PROXY_HTTP_URL=http://ssrf_proxy:3128
SSRF_PROXY_HTTPS_URL=http://ssrf_proxy:3128
