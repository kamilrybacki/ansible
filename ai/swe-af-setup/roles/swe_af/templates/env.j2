# SWE-AF environment – managed by Ansible
{% if swe_af_ai_provider == 'anthropic' %}
ANTHROPIC_API_KEY={{ swe_af_api_key }}
{% elif swe_af_ai_provider == 'claude_oauth' %}
CLAUDE_CODE_OAUTH_TOKEN={{ swe_af_api_key }}
{% elif swe_af_ai_provider == 'openrouter' %}
OPENROUTER_API_KEY={{ swe_af_api_key }}
{% endif %}

{% if swe_af_gh_token | default('') | length > 0 %}
GH_TOKEN={{ swe_af_gh_token }}
{% endif %}

AGENTFIELD_SERVER=http://control-plane:{{ swe_af_agentfield_port }}
NODE_ID=swe-planner
PORT={{ swe_af_agent_port }}
