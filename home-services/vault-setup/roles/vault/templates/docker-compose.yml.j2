# HashiCorp Vault Docker Compose – managed by Ansible
services:
  vault:
    image: {{ vault_image }}
    container_name: vault
    cap_add:
      - IPC_LOCK
    ports:
      - "{{ vault_bind_address }}:{{ vault_port }}:8200"
    volumes:
      - ./data:/vault/data
      - ./config:/vault/config:ro
      - ./logs:/vault/logs
    environment:
      VAULT_ADDR: "http://127.0.0.1:8200"
      VAULT_API_ADDR: "http://{{ vault_bind_address }}:{{ vault_port }}"
    command: vault server -config=/vault/config/vault.hcl
    restart: unless-stopped
    healthcheck:
      test: ["CMD", "vault", "status", "-format=json"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 15s
