# CLIProxyAPI Docker Compose – managed by Ansible
services:
  cli-proxy-api:
    image: {{ cliproxyapi_image }}
    container_name: cliproxyapi
    ports:
      - "{{ cliproxyapi_port }}:8317"
    volumes:
      - ./config.yaml:/CLIProxyAPI/config.yaml:ro
      - cliproxyapi-auth:/root/.cli-proxy-api
      - cliproxyapi-logs:/CLIProxyAPI/logs
    restart: unless-stopped

volumes:
  cliproxyapi-auth:
  cliproxyapi-logs:
