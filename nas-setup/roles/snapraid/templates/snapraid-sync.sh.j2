#!/bin/bash
# SnapRAID sync and scrub script
# Generated by Ansible - do not edit manually

LOG="/var/log/snapraid.log"
TIMESTAMP=$(date '+%Y-%m-%d %H:%M:%S')

echo "[$TIMESTAMP] Starting SnapRAID sync..." >> "$LOG"

# Count deleted files and abort if threshold exceeded
DEL_COUNT=$(snapraid diff 2>/dev/null | grep -c "^remove")
if [ "$DEL_COUNT" -gt {{ snapraid_delete_threshold }} ]; then
    echo "[$TIMESTAMP] ERROR: $DEL_COUNT deletions detected, exceeding threshold of {{ snapraid_delete_threshold }}. Aborting sync." >> "$LOG"
    exit 1
fi

# Run sync
snapraid sync >> "$LOG" 2>&1
SYNC_EXIT=$?

if [ $SYNC_EXIT -eq 0 ]; then
    echo "[$TIMESTAMP] SnapRAID sync completed successfully." >> "$LOG"
else
    echo "[$TIMESTAMP] ERROR: SnapRAID sync failed with exit code $SYNC_EXIT" >> "$LOG"
fi

exit $SYNC_EXIT
