# SnapRAID configuration file
# Generated by Ansible - do not edit manually
# Topology: {{ usb_data_drives | length }} data + {{ usb_parity_drives | length }} parity drives

# Parity file locations (on dedicated parity drives)
{% for idx in range(usb_parity_drives | length) %}
{% if idx == 0 %}
parity {{ parity_mount_base }}/parity{{ idx + 1 }}/snapraid.parity
{% else %}
{{ idx }}-parity {{ parity_mount_base }}/parity{{ idx + 1 }}/snapraid.parity
{% endif %}
{% endfor %}

# Content files (stored on each data drive for redundancy)
{% for idx in range(usb_data_drives | length) %}
content {{ data_mount_base }}/disk{{ idx + 1 }}/.snapraid.content
{% endfor %}

# Data drives
{% for idx in range(usb_data_drives | length) %}
data disk{{ idx + 1 }} {{ data_mount_base }}/disk{{ idx + 1 }}
{% endfor %}

# Exclude patterns
{% for pattern in snapraid_exclude_patterns %}
exclude {{ pattern }}
{% endfor %}

# Auto-save after 500 GB of processed data
autosave 500

# Block size in KB (default 256)
blocksize 256
