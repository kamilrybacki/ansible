#!/bin/bash
# SnapRAID scrub script — verifies data integrity
# Generated by Ansible - do not edit manually

LOG="/var/log/snapraid.log"
TIMESTAMP=$(date '+%Y-%m-%d %H:%M:%S')

echo "[$TIMESTAMP] Starting SnapRAID scrub..." >> "$LOG"

snapraid scrub -p 12 -o 10 >> "$LOG" 2>&1
SCRUB_EXIT=$?

if [ $SCRUB_EXIT -eq 0 ]; then
    echo "[$TIMESTAMP] SnapRAID scrub completed successfully." >> "$LOG"
else
    echo "[$TIMESTAMP] ERROR: SnapRAID scrub failed with exit code $SCRUB_EXIT" >> "$LOG"
fi

exit $SCRUB_EXIT
