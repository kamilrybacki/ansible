---
services:

  netbox:
    container_name: {{ netbox_container_name }}
    image: {{ netbox_image }}
{% if not (netbox_use_shared_db and netbox_use_shared_redis) %}
    depends_on:
{% if not netbox_use_shared_db %}
      - postgres
{% endif %}
{% if not netbox_use_shared_redis %}
      - redis
      - redis-cache
{% endif %}
{% endif %}
    ports:
      - "{{ netbox_bind_address }}:{{ netbox_port }}:8080"
    environment:
      ALLOWED_HOSTS: "{{ netbox_hostname }}.{{ saved_domain | default('localhost') }} localhost 127.0.0.1 {{ ansible_host }}"
      DB_HOST: "{{ netbox_db_host }}"
      DB_NAME: netbox
      DB_PASSWORD: "{{ netbox_db_password }}"
      DB_USER: netbox
{% if netbox_use_shared_redis %}
      REDIS_HOST: "{{ netbox_redis_host_resolved }}"
      REDIS_PASSWORD: "{{ netbox_shared_redis_password }}"
      REDIS_DATABASE: "{{ netbox_redis_db_number }}"
      REDIS_CACHE_HOST: "{{ netbox_redis_cache_host_resolved }}"
      REDIS_CACHE_PASSWORD: "{{ netbox_shared_redis_password }}"
      REDIS_CACHE_DATABASE: "{{ netbox_redis_cache_db_number }}"
{% else %}
      REDIS_HOST: redis
      REDIS_PASSWORD: "{{ netbox_redis_password }}"
      REDIS_CACHE_HOST: redis-cache
      REDIS_CACHE_PASSWORD: "{{ netbox_redis_cache_password }}"
{% endif %}
      SECRET_KEY: "{{ netbox_secret_key }}"
      SUPERUSER_NAME: "{{ netbox_admin_user }}"
      SUPERUSER_EMAIL: "{{ netbox_admin_email }}"
      SUPERUSER_PASSWORD: "${NETBOX_SUPERUSER_PASSWORD}"
      SUPERUSER_API_TOKEN: "${NETBOX_API_TOKEN}"
      SKIP_SUPERUSER: "false"
      TIME_ZONE: "{{ netbox_timezone }}"
{% if netbox_public_url | length > 0 %}
      CSRF_TRUSTED_ORIGINS: "{{ netbox_public_url }}"
{% endif %}
      # ── Authelia header SSO ─────────────────────────────────────────────────
      # Caddy's forward_auth passes Remote-User from Authelia; NetBox trusts
      # it and auto-creates/logs in the user.
      REMOTE_AUTH_ENABLED: "True"
      REMOTE_AUTH_BACKEND: "netbox.authentication.RemoteUserBackend"
      REMOTE_AUTH_HEADER: "HTTP_REMOTE_USER"
      REMOTE_AUTH_AUTO_CREATE_USER: "True"
      REMOTE_AUTH_DEFAULT_PERMISSIONS: "{}"
    volumes:
      - {{ netbox_data_dir }}/media:/opt/netbox/netbox/media
      - {{ netbox_data_dir }}/reports:/opt/netbox/netbox/reports
      - {{ netbox_data_dir }}/scripts:/opt/netbox/netbox/scripts
    restart: {{ netbox_restart_policy }}
    networks:
      - netbox-net
{% if netbox_use_shared_db or netbox_use_shared_redis %}
      - databases-net
{% endif %}

  netbox-worker:
    container_name: {{ netbox_container_name }}-worker
    image: {{ netbox_image }}
    command: /opt/netbox/venv/bin/python /opt/netbox/netbox/manage.py rqworker
    depends_on:
      - netbox
    environment:
      DB_HOST: "{{ netbox_db_host }}"
      DB_NAME: netbox
      DB_PASSWORD: "{{ netbox_db_password }}"
      DB_USER: netbox
{% if netbox_use_shared_redis %}
      REDIS_HOST: "{{ netbox_redis_host_resolved }}"
      REDIS_PASSWORD: "{{ netbox_shared_redis_password }}"
      REDIS_DATABASE: "{{ netbox_redis_db_number }}"
      REDIS_CACHE_HOST: "{{ netbox_redis_cache_host_resolved }}"
      REDIS_CACHE_PASSWORD: "{{ netbox_shared_redis_password }}"
      REDIS_CACHE_DATABASE: "{{ netbox_redis_cache_db_number }}"
{% else %}
      REDIS_HOST: redis
      REDIS_PASSWORD: "{{ netbox_redis_password }}"
      REDIS_CACHE_HOST: redis-cache
      REDIS_CACHE_PASSWORD: "{{ netbox_redis_cache_password }}"
{% endif %}
      SECRET_KEY: "{{ netbox_secret_key }}"
      SKIP_SUPERUSER: "true"
    volumes:
      - {{ netbox_data_dir }}/media:/opt/netbox/netbox/media
      - {{ netbox_data_dir }}/reports:/opt/netbox/netbox/reports
      - {{ netbox_data_dir }}/scripts:/opt/netbox/netbox/scripts
    restart: {{ netbox_restart_policy }}
    networks:
      - netbox-net
{% if netbox_use_shared_db or netbox_use_shared_redis %}
      - databases-net
{% endif %}

  netbox-housekeeping:
    container_name: {{ netbox_container_name }}-housekeeping
    image: {{ netbox_image }}
    command: /opt/netbox/housekeeping.sh
    depends_on:
      - netbox
    environment:
      DB_HOST: "{{ netbox_db_host }}"
      DB_NAME: netbox
      DB_PASSWORD: "{{ netbox_db_password }}"
      DB_USER: netbox
{% if netbox_use_shared_redis %}
      REDIS_HOST: "{{ netbox_redis_host_resolved }}"
      REDIS_PASSWORD: "{{ netbox_shared_redis_password }}"
      REDIS_DATABASE: "{{ netbox_redis_db_number }}"
      REDIS_CACHE_HOST: "{{ netbox_redis_cache_host_resolved }}"
      REDIS_CACHE_PASSWORD: "{{ netbox_shared_redis_password }}"
      REDIS_CACHE_DATABASE: "{{ netbox_redis_cache_db_number }}"
{% else %}
      REDIS_HOST: redis
      REDIS_PASSWORD: "{{ netbox_redis_password }}"
      REDIS_CACHE_HOST: redis-cache
      REDIS_CACHE_PASSWORD: "{{ netbox_redis_cache_password }}"
{% endif %}
      SECRET_KEY: "{{ netbox_secret_key }}"
      SKIP_SUPERUSER: "true"
    volumes:
      - {{ netbox_data_dir }}/media:/opt/netbox/netbox/media
    restart: {{ netbox_restart_policy }}
    networks:
      - netbox-net
{% if netbox_use_shared_db or netbox_use_shared_redis %}
      - databases-net
{% endif %}

{% if not netbox_use_shared_db %}
  postgres:
    container_name: {{ netbox_container_name }}-postgres
    image: {{ netbox_postgres_image }}
    environment:
      POSTGRES_DB: netbox
      POSTGRES_USER: netbox
      POSTGRES_PASSWORD: "{{ netbox_db_password }}"
    volumes:
      - netbox-postgres-data:/var/lib/postgresql/data
    restart: {{ netbox_restart_policy }}
    networks:
      - netbox-net

{% endif %}
{% if not netbox_use_shared_redis %}
  redis:
    container_name: {{ netbox_container_name }}-redis
    image: {{ netbox_redis_image }}
    command: valkey-server --requirepass {{ netbox_redis_password }}
    volumes:
      - netbox-redis-data:/data
    restart: {{ netbox_restart_policy }}
    networks:
      - netbox-net

  redis-cache:
    container_name: {{ netbox_container_name }}-redis-cache
    image: {{ netbox_redis_image }}
    command: valkey-server --requirepass {{ netbox_redis_cache_password }}
    restart: {{ netbox_restart_policy }}
    networks:
      - netbox-net

{% endif %}
{% if not (netbox_use_shared_db and netbox_use_shared_redis) %}
volumes:
{% if not netbox_use_shared_db %}
  netbox-postgres-data:
{% endif %}
{% if not netbox_use_shared_redis %}
  netbox-redis-data:
{% endif %}
{% endif %}

networks:
  netbox-net:
    driver: bridge
{% if netbox_use_shared_db or netbox_use_shared_redis %}
  databases-net:
    external: true
{% endif %}
