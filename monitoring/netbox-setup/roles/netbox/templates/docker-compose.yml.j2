---
services:

  netbox:
    container_name: {{ netbox_container_name }}
    image: {{ netbox_image }}
    depends_on:
      - postgres
      - redis
      - redis-cache
    ports:
      - "{{ netbox_bind_address }}:{{ netbox_port }}:8080"
    environment:
      ALLOWED_HOSTS: "{{ netbox_hostname }}.{{ saved_domain | default('localhost') }} localhost 127.0.0.1"
      DB_HOST: postgres
      DB_NAME: netbox
      DB_PASSWORD: "{{ netbox_db_password }}"
      DB_USER: netbox
      REDIS_HOST: redis
      REDIS_PASSWORD: "{{ netbox_redis_password }}"
      REDIS_CACHE_HOST: redis-cache
      REDIS_CACHE_PASSWORD: "{{ netbox_redis_cache_password }}"
      SECRET_KEY: "{{ netbox_secret_key }}"
      SUPERUSER_NAME: "{{ netbox_admin_user }}"
      SUPERUSER_EMAIL: "{{ netbox_admin_email }}"
      SUPERUSER_PASSWORD: "${NETBOX_SUPERUSER_PASSWORD}"
      SUPERUSER_API_TOKEN: "${NETBOX_API_TOKEN}"
      SKIP_SUPERUSER: "false"
      TIME_ZONE: "{{ netbox_timezone }}"
{% if netbox_public_url | length > 0 %}
      CSRF_TRUSTED_ORIGINS: "{{ netbox_public_url }}"
{% endif %}
    volumes:
      - {{ netbox_data_dir }}/media:/opt/netbox/netbox/media
      - {{ netbox_data_dir }}/reports:/opt/netbox/netbox/reports
      - {{ netbox_data_dir }}/scripts:/opt/netbox/netbox/scripts
    restart: {{ netbox_restart_policy }}
    networks:
      - netbox-net

  netbox-worker:
    container_name: {{ netbox_container_name }}-worker
    image: {{ netbox_image }}
    command: /opt/netbox/venv/bin/python /opt/netbox/netbox/manage.py rqworker
    depends_on:
      - netbox
    environment:
      DB_HOST: postgres
      DB_NAME: netbox
      DB_PASSWORD: "{{ netbox_db_password }}"
      DB_USER: netbox
      REDIS_HOST: redis
      REDIS_PASSWORD: "{{ netbox_redis_password }}"
      REDIS_CACHE_HOST: redis-cache
      REDIS_CACHE_PASSWORD: "{{ netbox_redis_cache_password }}"
      SECRET_KEY: "{{ netbox_secret_key }}"
      SKIP_SUPERUSER: "true"
    volumes:
      - {{ netbox_data_dir }}/media:/opt/netbox/netbox/media
      - {{ netbox_data_dir }}/reports:/opt/netbox/netbox/reports
      - {{ netbox_data_dir }}/scripts:/opt/netbox/netbox/scripts
    restart: {{ netbox_restart_policy }}
    networks:
      - netbox-net

  netbox-housekeeping:
    container_name: {{ netbox_container_name }}-housekeeping
    image: {{ netbox_image }}
    command: /opt/netbox/housekeeping.sh
    depends_on:
      - netbox
    environment:
      DB_HOST: postgres
      DB_NAME: netbox
      DB_PASSWORD: "{{ netbox_db_password }}"
      DB_USER: netbox
      REDIS_HOST: redis
      REDIS_PASSWORD: "{{ netbox_redis_password }}"
      REDIS_CACHE_HOST: redis-cache
      REDIS_CACHE_PASSWORD: "{{ netbox_redis_cache_password }}"
      SECRET_KEY: "{{ netbox_secret_key }}"
      SKIP_SUPERUSER: "true"
    volumes:
      - {{ netbox_data_dir }}/media:/opt/netbox/netbox/media
    restart: {{ netbox_restart_policy }}
    networks:
      - netbox-net

  postgres:
    container_name: {{ netbox_container_name }}-postgres
    image: {{ netbox_postgres_image }}
    environment:
      POSTGRES_DB: netbox
      POSTGRES_USER: netbox
      POSTGRES_PASSWORD: "{{ netbox_db_password }}"
    volumes:
      - netbox-postgres-data:/var/lib/postgresql/data
    restart: {{ netbox_restart_policy }}
    networks:
      - netbox-net

  redis:
    container_name: {{ netbox_container_name }}-redis
    image: {{ netbox_redis_image }}
    command: valkey-server --requirepass {{ netbox_redis_password }}
    volumes:
      - netbox-redis-data:/data
    restart: {{ netbox_restart_policy }}
    networks:
      - netbox-net

  redis-cache:
    container_name: {{ netbox_container_name }}-redis-cache
    image: {{ netbox_redis_image }}
    command: valkey-server --requirepass {{ netbox_redis_cache_password }}
    restart: {{ netbox_restart_policy }}
    networks:
      - netbox-net

volumes:
  netbox-postgres-data:
  netbox-redis-data:

networks:
  netbox-net:
    driver: bridge
