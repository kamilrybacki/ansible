services:
  grafana:
    image: {{ grafana_image }}
    container_name: grafana
    restart: {{ grafana_restart_policy }}
    ports:
      - "{{ grafana_bind_address }}:{{ grafana_port }}:3000"
    environment:
      GF_SECURITY_ADMIN_USER: "{{ grafana_admin_user }}"
      GF_SECURITY_ADMIN_PASSWORD: "{{ grafana_admin_password }}"
      GF_SERVER_ROOT_URL: "{{ grafana_public_url if grafana_public_url else 'http://localhost:' + grafana_port|string }}"
      GF_USERS_ALLOW_SIGN_UP: "false"
      GF_DATE_FORMATS_DEFAULT_TIMEZONE: "{{ grafana_timezone }}"
{% if grafana_oidc_client_secret | default('') %}
      # ── Authelia OIDC SSO ───────────────────────────────────────────────────
      GF_AUTH_GENERIC_OAUTH_ENABLED: "true"
      GF_AUTH_GENERIC_OAUTH_NAME: "Authelia"
      GF_AUTH_GENERIC_OAUTH_CLIENT_ID: "grafana"
      GF_AUTH_GENERIC_OAUTH_CLIENT_SECRET: "{{ grafana_oidc_client_secret }}"
      GF_AUTH_GENERIC_OAUTH_SCOPES: "openid profile email groups"
      GF_AUTH_GENERIC_OAUTH_AUTH_URL: "https://{{ grafana_oidc_auth_domain }}/api/oidc/authorization"
      GF_AUTH_GENERIC_OAUTH_TOKEN_URL: "https://{{ grafana_oidc_auth_domain }}/api/oidc/token"
      GF_AUTH_GENERIC_OAUTH_API_URL: "https://{{ grafana_oidc_auth_domain }}/api/oidc/userinfo"
      GF_AUTH_GENERIC_OAUTH_USE_PKCE: "true"
      GF_AUTH_GENERIC_OAUTH_AUTO_LOGIN: "true"
      GF_AUTH_GENERIC_OAUTH_ROLE_ATTRIBUTE_PATH: "'GrafanaAdmin'"
      GF_AUTH_SIGNOUT_REDIRECT_URL: "https://{{ grafana_oidc_auth_domain }}/logout"
      GF_AUTH_DISABLE_LOGIN_FORM: "true"
      GF_AUTH_GENERIC_OAUTH_ROLE_ATTRIBUTE_STRICT: "true"
{% endif %}
    volumes:
      - grafana_data:/var/lib/grafana
      - ./provisioning:/etc/grafana/provisioning:ro

  alloy:
    image: {{ alloy_image }}
    container_name: alloy
    restart: {{ grafana_restart_policy }}
    dns:
      - {{ pihole_dns_ip | default('1.1.1.1') }}
{% if probe_extra_hosts | default([]) | length > 0 %}
    extra_hosts:
{% for domain in probe_extra_hosts %}
      - "{{ domain }}:{{ caddy_homelab_ip }}"
{% endfor %}
{% endif %}
{% if vault_metrics_token | default('') | length > 0 %}
    environment:
      VAULT_METRICS_TOKEN: "{{ vault_metrics_token }}"
{% endif %}
    volumes:
      - ./alloy/config.alloy:/etc/alloy/config.alloy:ro
      - /var/run/docker.sock:/var/run/docker.sock:ro
      - /var/log:/var/log:ro
      - /proc:/host/proc:ro
      - /sys:/host/sys:ro
      - /var/lib/docker:/var/lib/docker:ro
    command: run /etc/alloy/config.alloy
    pid: host
    privileged: true
    networks:
      - default
      - homelab-net

  docker-exporter:
    image: {{ docker_exporter_image }}
    container_name: docker-exporter
    restart: {{ grafana_restart_policy }}
    user: "0:0"
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock:ro

volumes:
  grafana_data:

networks:
  default:
  homelab-net:
    external: true
