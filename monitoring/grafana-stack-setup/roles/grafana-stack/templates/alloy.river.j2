  forward_to      = [prometheus.relabel.caddy_labels.receiver]
  scrape_interval = "60s"
}

prometheus.relabel "caddy_labels" {
  forward_to = [prometheus.remote_write.mimir.receiver]
  rule { target_label = "job";     replacement = "security" }
