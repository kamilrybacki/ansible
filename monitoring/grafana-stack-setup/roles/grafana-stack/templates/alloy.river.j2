// ── Remote write endpoints ────────────────────────────────────────────────────
prometheus.remote_write "mimir" {
  endpoint {
    url = "http://mimir:{{ mimir_port }}/api/v1/push"
  }
}

loki.write "loki" {
  endpoint {
    url = "http://loki:{{ loki_port }}/loki/api/v1/push"
  }
}
