# librenms-setup/roles/librenms/templates/docker-compose.yml.j2
---
services:
  db:
    image: mariadb:10.11
    container_name: librenms_db
    restart: unless-stopped
    command:
      - "mysqld"
      - "--innodb-file-per-table=1"
      - "--lower-case-table-names=0"
      - "--character-set-server=utf8mb4"
      - "--collation-server=utf8mb4_unicode_ci"
    environment:
      MYSQL_ROOT_PASSWORD: "{{ librenms_db_root_password }}"
      MYSQL_DATABASE: librenms
      MYSQL_USER: librenms
      MYSQL_PASSWORD: "{{ librenms_db_password }}"
    volumes:
      - db_data:/var/lib/mysql

  redis:
    image: redis:7-alpine
    container_name: librenms_redis
    restart: unless-stopped

  librenms:
    image: librenms/librenms:{{ librenms_version }}
    container_name: librenms_app
    hostname: librenms
    restart: unless-stopped
    ports:
      - "{{ librenms_port }}:8000"
    environment:
      TZ: "{{ librenms_timezone }}"
      DB_HOST: db
      DB_USER: librenms
      DB_PASSWORD: "{{ librenms_db_password }}"
      DB_NAME: librenms
      REDIS_HOST: redis
      REDIS_PORT: 6379
      REDIS_DB: 0
      # ── Authelia header SSO ─────────────────────────────────────────────────
      # Caddy forward_auth injects Remote-User; LibreNMS reads it directly.
      AUTH_MECHANISM: "header"
      AUTH_HEADER: "REMOTE_USER"
    volumes:
      - librenms_data:/data
    depends_on:
      - db
      - redis

  dispatcher:
    image: librenms/librenms:{{ librenms_version }}
    container_name: librenms_dispatcher
    hostname: librenms-dispatcher
    restart: unless-stopped
    environment:
      TZ: "{{ librenms_timezone }}"
      DB_HOST: db
      DB_USER: librenms
      DB_PASSWORD: "{{ librenms_db_password }}"
      DB_NAME: librenms
      REDIS_HOST: redis
      REDIS_PORT: 6379
      REDIS_DB: 0
      DISPATCHER_NODE_ID: dispatcher1
      SIDECAR_DISPATCHER: 1
    volumes:
      - librenms_data:/data
    depends_on:
      - librenms

  syslog:
    image: librenms/librenms:{{ librenms_version }}
    container_name: librenms_syslog
    hostname: librenms-syslog
    restart: unless-stopped
    ports:
      - "514:514/udp"
      - "514:514/tcp"
    environment:
      TZ: "{{ librenms_timezone }}"
      DB_HOST: db
      DB_USER: librenms
      DB_PASSWORD: "{{ librenms_db_password }}"
      DB_NAME: librenms
      REDIS_HOST: redis
      REDIS_PORT: 6379
      REDIS_DB: 0
      SIDECAR_SYSLOGNG: 1
    volumes:
      - librenms_data:/data
    depends_on:
      - librenms

volumes:
  db_data:
  librenms_data:
